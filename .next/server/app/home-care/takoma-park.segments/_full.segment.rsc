1d:T8f5,{"@context":"https://schema.org","@graph":[{"@type":["HomeAndConstructionBusiness","MedicalBusiness","LocalBusiness"],"name":"Vitalis HealthCare Services","url":"https://www.vitalishealthcare.com/home-care/takoma-park","telephone":"+12407166874","email":"info@vitalishealthcare.com","address":{"@type":"PostalAddress","streetAddress":"8757 Georgia Avenue, Suite 440","addressLocality":"Silver Spring","addressRegion":"MD","postalCode":"20910","addressCountry":"US"},"areaServed":["Takoma Park","Montgomery County","Maryland"],"openingHours":["Mo-Fr 09:00-17:00","Sa 10:00-16:00"],"hasCredential":["OHCQ License #3879R","Joint Commission Gold Seal Certification","CareScout Approved Provider"]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do you serve Takoma Park, MD?","acceptedAnswer":{"@type":"Answer","text":"Yes — we serve Takoma Park including Old Takoma, Piney Branch, and the Carroll and Maple Avenue corridors. Our Silver Spring office is just minutes away, which means fast response times."}},{"@type":"Question","name":"Can you help with care after a hospital stay at Washington Adventist?","acceptedAnswer":{"@type":"Answer","text":"Yes. We regularly help families transition a loved one home from local hospitals and rehab centers. We can often be in contact with the discharge team before your loved one even leaves the facility."}},{"@type":"Question","name":"My mother lives alone in Takoma Park. Can someone check on her daily?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. We offer flexible scheduling from a few hours per day to full-time live-in care. Many families start with a daily check-in and companion visit and adjust from there as needs change."}},{"@type":"Question","name":"Is home care available on weekends in Takoma Park?","acceptedAnswer":{"@type":"Answer","text":"Yes — we provide care 7 days a week including weekends and holidays. We also have a 24/7 coordination line for urgent situations."}},{"@type":"Question","name":"Does Vitalis accept DC-based Medicaid for Takoma Park clients?","acceptedAnswer":{"@type":"Answer","text":"We primarily work with Maryland Medicaid Waiver. If your loved one has DC insurance, call us and we'll help clarify what options are available based on their specific situation and address."}}]}]}14:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","nav",null,{"className":"nav-sticky","children":["$","div",null,{"className":"nav-inner","style":{"display":"flex","alignItems":"center","justifyContent":"space-between","padding":"16px 48px","maxWidth":"1280px","margin":"0 auto"},"children":[["$","$L4",null,{"href":"/","style":{"display":"flex","alignItems":"center","gap":"10px"},"children":[["$","svg",null,{"width":"34","height":"34","viewBox":"0 0 34 34","fill":"none","children":[["$","rect",null,{"width":"34","height":"34","rx":"9","fill":"#eaf3de"}],["$","text",null,{"x":"17","y":"23","textAnchor":"middle","fontFamily":"Georgia,serif","fontSize":"13","fontWeight":"500","fill":"#27500a","children":"V+"}]]}],["$","span",null,{"style":{"fontFamily":"var(--font-lora), Georgia, serif","fontSize":"17px","color":"var(--text)"},"children":"Vitalis HealthCare"}]]}],["$","div",null,{"className":"nav-links","style":{"display":"flex","gap":"28px"},"children":[["$","$L4",null,{"href":"/#services","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Services"}],["$","$L4",null,{"href":"/#conditions","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Conditions"}],["$","$L4",null,{"href":"/#team","style":{"fontSize":"14px","color":"var(--muted)"},"children":"About Us"}],["$","$L4",null,{"href":"/blog","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Blog"}],"$L1e"]}],"$L1f"]}]}],"$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29"]
