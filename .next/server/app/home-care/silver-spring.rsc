1d:T969,{"@context":"https://schema.org","@graph":[{"@type":["HomeAndConstructionBusiness","MedicalBusiness","LocalBusiness"],"name":"Vitalis HealthCare Services","url":"https://www.vitalishealthcare.com/home-care/silver-spring","telephone":"+12407166874","email":"info@vitalishealthcare.com","address":{"@type":"PostalAddress","streetAddress":"8757 Georgia Avenue, Suite 440","addressLocality":"Silver Spring","addressRegion":"MD","postalCode":"20910","addressCountry":"US"},"areaServed":["Silver Spring","Montgomery County","Maryland"],"openingHours":["Mo-Fr 09:00-17:00","Sa 10:00-16:00"],"hasCredential":["OHCQ License #3879R","Joint Commission Gold Seal Certification","CareScout Approved Provider"]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do you serve all of Silver Spring?","acceptedAnswer":{"@type":"Answer","text":"Yes — we serve all neighborhoods in Silver Spring including Wheaton, Kemp Mill, White Oak, Four Corners, Aspen Hill, and the Downtown area. If you're not sure whether you're in our service area, just call and we'll confirm right away."}},{"@type":"Question","name":"How quickly can care start in Silver Spring?","acceptedAnswer":{"@type":"Answer","text":"In most cases, we can begin care within 24–48 hours of your first call. For urgent situations — like a hospital discharge — we can often arrange same-day or next-morning care. We're local, so we move quickly."}},{"@type":"Question","name":"Do you work with Silver Spring hospitals and rehab facilities?","acceptedAnswer":{"@type":"Answer","text":"Yes. We coordinate with Holy Cross Hospital, Washington Adventist Hospital, and local rehab facilities to help families transition home safely after a stay. We can often meet with discharge planners directly."}},{"@type":"Question","name":"Does Maryland Medicaid cover home care in Silver Spring?","acceptedAnswer":{"@type":"Answer","text":"Yes. If your loved one qualifies for the Maryland Medicaid Waiver program, home care services may be covered at little or no cost. We can help you understand eligibility and navigate the application process."}},{"@type":"Question","name":"What languages do your Silver Spring caregivers speak?","acceptedAnswer":{"@type":"Answer","text":"Our caregiver team reflects the diversity of Silver Spring. We have Spanish, French, and Amharic-speaking caregivers available. Just let us know your preference when you call."}}]}]}14:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","nav",null,{"className":"nav-sticky","children":["$","div",null,{"className":"nav-inner","style":{"display":"flex","alignItems":"center","justifyContent":"space-between","padding":"16px 48px","maxWidth":"1280px","margin":"0 auto"},"children":[["$","$L4",null,{"href":"/","style":{"display":"flex","alignItems":"center","gap":"10px"},"children":[["$","svg",null,{"width":"34","height":"34","viewBox":"0 0 34 34","fill":"none","children":[["$","rect",null,{"width":"34","height":"34","rx":"9","fill":"#eaf3de"}],["$","text",null,{"x":"17","y":"23","textAnchor":"middle","fontFamily":"Georgia,serif","fontSize":"13","fontWeight":"500","fill":"#27500a","children":"V+"}]]}],["$","span",null,{"style":{"fontFamily":"var(--font-lora), Georgia, serif","fontSize":"17px","color":"var(--text)"},"children":"Vitalis HealthCare"}]]}],["$","div",null,{"className":"nav-links","style":{"display":"flex","gap":"28px"},"children":[["$","$L4",null,{"href":"/#services","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Services"}],["$","$L4",null,{"href":"/#conditions","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Conditions"}],["$","$L4",null,{"href":"/#team","style":{"fontSize":"14px","color":"var(--muted)"},"children":"About Us"}],"$L1e","$L1f"]}],"$L20"]}]}],"$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a"]
