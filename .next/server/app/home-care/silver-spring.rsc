24:["$","section",null,{"className":"sec","children":["$","div",null,{"className":"inner","children":["$","div",null,{"className":"two-col","children":[["$","div",null,{"children":[["$","p",null,{"className":"sec-label","children":["About our ","Silver Spring"," care"]}],["$","h2",null,{"className":"sec-h","children":["Home care built for ","Silver Spring"," families."]}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Silver Spring is where we're rooted. Our office is here, our caregivers live here, and we've been caring for Silver Spring families for years. When you call us, you're not talking to a national call center — you're talking to a local team that knows Georgia Avenue, knows the neighborhoods, and knows what families in this community need."}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Our office is right here in Silver Spring at 8757 Georgia Avenue — so when you need us, we're never far. We know the traffic on Georgia Ave. We know the Wheaton Metro area. We know the senior living communities nearby. That local knowledge makes a real difference when we're coordinating care for your family. As a BCHD-contracted agency, Vitalis is held to Montgomery County's highest standards for home care delivery."}],["$","p",null,{"className":"sec-p","children":["We serve families in ","Wheaton, Kemp Mill, White Oak, Four Corners, Aspen Hill, and Downtown Silver Spring","."]}]]}],["$","div",null,{"style":{"display":"flex","flexDirection":"column","gap":"16px"},"children":[["$","div","15+",{"className":"card-green","style":{"textAlign":"center"},"children":[["$","div",null,{"className":"stat-n","children":"15+"}],["$","div",null,{"className":"stat-l","children":"Years serving Silver Spring families"}]]}],["$","div","24/7",{"className":"card-green","style":{"textAlign":"center"},"children":[["$","div",null,{"className":"stat-n","children":"24/7"}],["$","div",null,{"className":"stat-l","children":"Local care