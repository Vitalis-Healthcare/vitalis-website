1d:T97f,{"@context":"https://schema.org","@graph":[{"@type":["HomeAndConstructionBusiness","MedicalBusiness","LocalBusiness"],"name":"Vitalis HealthCare Services","url":"https://www.vitalishealthcare.com/home-care/annapolis","telephone":"+12407166874","email":"info@vitalishealthcare.com","address":{"@type":"PostalAddress","streetAddress":"8757 Georgia Avenue, Suite 440","addressLocality":"Silver Spring","addressRegion":"MD","postalCode":"20910","addressCountry":"US"},"areaServed":["Annapolis","Anne Arundel County","Maryland"],"openingHours":["Mo-Fr 09:00-17:00","Sa 10:00-16:00"],"hasCredential":["OHCQ License #3879R","Joint Commission Gold Seal Certification","CareScout Approved Provider"]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do you serve Annapolis and Anne Arundel County?","acceptedAnswer":{"@type":"Answer","text":"Yes — we serve Annapolis and surrounding Anne Arundel County communities including Parole, Hillsmere Shores, Riva, Edgewater, Arnold, and Severna Park. Call us to confirm coverage for your specific address."}},{"@type":"Question","name":"How quickly can care begin in Annapolis?","acceptedAnswer":{"@type":"Answer","text":"In most cases, we can arrange care within 24–48 hours of an initial consultation. For urgent hospital discharges, we work to get support in place as quickly as possible — sometimes the same day."}},{"@type":"Question","name":"Do you accept Long-Term Care Insurance for Annapolis clients?","acceptedAnswer":{"@type":"Answer","text":"Yes. Most Long-Term Care Insurance policies cover our home care services. We'll work with your insurer directly to confirm your benefits and handle the documentation needed to activate coverage."}},{"@type":"Question","name":"Can your nurses work with my parent's Annapolis-area doctor?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Our clinical team communicates with primary care physicians, specialists, and hospital discharge teams to make sure care is coordinated and nothing falls through the cracks."}},{"@type":"Question","name":"What makes Vitalis different from a national franchise?","acceptedAnswer":{"@type":"Answer","text":"We're a locally rooted Maryland agency — not a franchise with rotating staff and 800-number support. You get a dedicated case manager, consistent caregivers, and direct access to our clinical team. Families tell us that personal accountability is what they value most."}}]}]}14:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","nav",null,{"className":"nav-sticky","children":["$","div",null,{"className":"nav-inner","style":{"display":"flex","alignItems":"center","justifyContent":"space-between","padding":"16px 48px","maxWidth":"1280px","margin":"0 auto"},"children":[["$","$L4",null,{"href":"/","style":{"display":"flex","alignItems":"center","gap":"10px"},"children":[["$","svg",null,{"width":"34","height":"34","viewBox":"0 0 34 34","fill":"none","children":[["$","rect",null,{"width":"34","height":"34","rx":"9","fill":"#eaf3de"}],["$","text",null,{"x":"17","y":"23","textAnchor":"middle","fontFamily":"Georgia,serif","fontSize":"13","fontWeight":"500","fill":"#27500a","children":"V+"}]]}],["$","span",null,{"style":{"fontFamily":"var(--font-lora), Georgia, serif","fontSize":"17px","color":"var(--text)"},"children":"Vitalis HealthCare"}]]}],["$","div",null,{"className":"nav-links","style":{"display":"flex","gap":"28px"},"children":[["$","$L4",null,{"href":"/#services","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Services"}],["$","$L4",null,{"href":"/#conditions","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Conditions"}],"$L1e","$L1f","$L20"]}],"$L21"]}]}],"$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b"]
