8:["$","div",null,{"className":"trust-bar","children":[["$","div","0",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"MD License"}],["$","div",null,{"className":"ti-val","children":"OHCQ #3879R"}]]}],["$","div","1",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Certified"}],["$","div",null,{"className":"ti-val","children":"Joint Commission Gold Seal"}]]}],["$","div","2",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Network"}],["$","div",null,{"className":"ti-val","children":"CareScout Approved"}]]}],["$","div","3",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Contract"}],["$","div",null,{"className":"ti-val","children":"BCHD · Montgomery County"}]]}],["$","div","4",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Payment"}],["$","div",null,{"className":"ti-val","children":"VA · Medicaid · LTC · Private Pay"}]]}],["$","div","5",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Available"}],["$","div",null,{"className":"ti-val","children":"24 Hours · 7 Days"}]]}]]}]
9:["$","section",null,{"className":"sec","children":["$","div",null,{"className":"inner","children":[["$","p",null,{"className":"sec-label","children":"Understanding the need"}],["$","h2",null,{"className":"sec-h","children":["What is ","Fall Prevention for Seniors"," at home?"]}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Fall prevention care combines home safety assessment, daily physical assistance, mobility support, and consistent caregiver presence to dramatically reduce the risk of falls for seniors living at home. It's proactive, not reactive — and it's far less costly than the aftermath of a serious fall."}],["$","p",null,{"className":"sec-p","children":"Falls are the number one cause of serious injury for adults over 65 — and most of them happen at home, in familiar places, during routine moments. A fall can end independence in an instant. At Vitalis HealthCare, we take fall prevention seriously: not just with tips, but with trained caregivers who are physically present to make sure your loved one moves safely every single day."}]]}]}]
a:["$","section",null,{"className":"sec sec-alt","children":["$","div",null,{"className":"inner-wide","children":[["$","p",null,{"className":"sec-label","children":"Signs it's time to call"}],["$","h2",null,{"className":"sec-h","children":"How do you know when professional care is needed?"}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"28px"},"children":"Families often wait too long — not because they don't care, but because they're not sure the situation is serious enough. Here are the signs to look for."}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(3,1fr)","gap":"18px"},"children":[["$","div","A recent fall or near-miss",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"A recent fall or near-miss"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Your loved one has already fallen once — and statistically, that makes another fall much more likely. This is the strongest signal that professional support is needed."}]]}],["$","div","Balance or gait problems",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Balance or gait problems"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Shuffling walk, difficulty rising from chairs, unsteady movement, or a tendency to hold walls and furniture are all warning signs of high fall risk."}]]}],["$","div","Fear of falling",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Fear of falling"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Seniors who are afraid of falling often become less active — which weakens muscles and actually increases fall risk. Breaking this cycle requires both support and encouragement."}]]}],["$","div","Cluttered or unsafe home environment",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Cluttered or unsafe home environment"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Loose rugs, poor lighting, stairs without railings, and bathroom hazards contribute significantly to fall risk — and most are fixable."}]]}],["$","div","Medication side effects",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Medication side effects"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Many common medications — blood pressure drugs, sleep aids, pain medications — affect balance and reaction time, especially in combination."}]]}]]}]]}]}]
