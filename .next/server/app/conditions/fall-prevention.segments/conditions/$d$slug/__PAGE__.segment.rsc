athroom, navigating stairs, and all the routine moments where falls most often happen."}]]}]]}],["$","div","Exercise and strength support",{"style":{"display":"flex","gap":"16px","alignItems":"flex-start","padding":"18px 0","borderBottom":"1px solid #d4e8b8"},"children":[["$","div",null,{"style":{"width":32,"height":32,"borderRadius":"50%","background":"#fff","border":"1px solid #97c459","display":"flex","alignItems":"center","justifyContent":"center","flexShrink":0,"fontSize":"14px","color":"var(--g-bd)"},"children":"✓"}],["$","div",null,{"children":[["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"5px"},"children":"Exercise and strength support"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Gentle movement and strength routines — recommended by your loved one's doctor or therapist — help maintain the muscle strength and balance that prevent falls."}]]}]]}],["$","div","Medication awareness",{"style":{"display":"flex","gap":"16px","alignItems":"flex-start","padding":"18px 0","borderBottom":"1px solid #d4e8b8"},"children":[["$","div",null,{"style":{"width":32,"height":32,"borderRadius":"50%","background":"#fff","border":"1px solid #97c459","display":"flex","alignItems":"center","justifyContent":"center","flexShrink":0,"fontSize":"14px","color":"var(--g-bd)"},"children":"✓"}],["$","div",null,{"children":[["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"5px"},"children":"Medication awareness"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"We monitor for medications that increase dizziness or unsteadiness, and coordinate with your medical team when concerns arise."}]]}]]}],["$","div","Emergency response planning",{"style":{"display":"flex","gap":"16px","alignItems":"flex-start","padding":"18px 0","borderBottom":"1px solid #d4e8b8"},"children":[["$","div",null,{"style":{"wi