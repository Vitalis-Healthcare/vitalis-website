1d:T86a,{"@context":"https://schema.org","@graph":[{"@type":"MedicalWebPage","name":"Vitalis HealthCare — Stroke Recovery Support in Silver Spring, MD","url":"https://www.vitalishealthcare.com/conditions/stroke","description":"Stroke recovery home care in Silver Spring, Rockville & Montgomery County, MD. Daily routines, therapy support, and RN supervision. Licensed & certified. Call 240.716.6874.","medicalSpecialty":"Home Health Care"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How soon after a stroke can home care start?","acceptedAnswer":{"@type":"Answer","text":"We can begin care as soon as your loved one is discharged from hospital or rehabilitation. Many families contact us while their loved one is still in rehab so we can plan for a seamless transition home."}},{"@type":"Question","name":"Do your caregivers work alongside physical and occupational therapists?","acceptedAnswer":{"@type":"Answer","text":"Yes. We coordinate with your therapy team and reinforce prescribed exercises and routines in between formal therapy sessions. Good home care and good therapy work together."}},{"@type":"Question","name":"How long does stroke recovery home care typically last?","acceptedAnswer":{"@type":"Answer","text":"It varies significantly by the severity of the stroke and individual progress. Some clients need intensive support for a few months; others benefit from ongoing moderate support for a year or more. We reassess regularly."}},{"@type":"Question","name":"Does Maryland Medicaid cover home care for stroke survivors?","acceptedAnswer":{"@type":"Answer","text":"Depending on eligibility, the Maryland Medicaid Waiver program may cover home care for stroke survivors. VA benefits may also apply for veteran stroke survivors. We'll help you explore all options."}},{"@type":"Question","name":"What if my loved one is depressed or resistant to help after their stroke?","acceptedAnswer":{"@type":"Answer","text":"This is very common. Our caregivers are experienced with the emotional side of stroke recovery — they're patient, encouraging, and skilled at building trust with clients who are frustrated or withdrawn."}}]}]}14:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1d"}}],["$","nav",null,{"className":"nav-sticky","children":["$","div",null,{"className":"nav-inner","style":{"display":"flex","alignItems":"center","justifyContent":"space-between","padding":"16px 48px","maxWidth":"1280px","margin":"0 auto"},"children":[["$","$L4",null,{"href":"/","style":{"display":"flex","alignItems":"center","gap":"10px"},"children":[["$","svg",null,{"width":"34","height":"34","viewBox":"0 0 34 34","fill":"none","children":[["$","rect",null,{"width":"34","height":"34","rx":"9","fill":"#eaf3de"}],["$","text",null,{"x":"17","y":"23","textAnchor":"middle","fontFamily":"Georgia,serif","fontSize":"13","fontWeight":"500","fill":"#27500a","children":"V+"}]]}],["$","span",null,{"style":{"fontFamily":"var(--font-lora), Georgia, serif","fontSize":"17px","color":"var(--text)"},"children":"Vitalis HealthCare"}]]}],["$","div",null,{"className":"nav-links","style":{"display":"flex","gap":"28px"},"children":[["$","$L4",null,{"href":"/#services","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Services"}],["$","$L4",null,{"href":"/#conditions","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Conditions"}],["$","$L4",null,{"href":"/#team","style":{"fontSize":"14px","color":"var(--muted)"},"children":"About Us"}],["$","$L4",null,{"href":"/blog","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Blog"}],["$","$L4",null,{"href":"/careers","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Careers"}]]}],["$","div",null,{"style":{"display":"flex","alignItems":"center","gap":"20px"},"children":[["$","a",null,{"href":"tel:2407166874","style":{"fontSize":"14px","fontWeight":500,"color":"var(--g-bd)"},"children":"240.716.6874"}],"$L1e"]}]]}]}],"$L1f","$L20","$L21","$L22","$L2