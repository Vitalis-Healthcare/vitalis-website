21:["$","div",null,{"className":"trust-bar","children":[["$","div","0",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"MD License"}],["$","div",null,{"className":"ti-val","children":"OHCQ #3879R"}]]}],["$","div","1",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Certified"}],["$","div",null,{"className":"ti-val","children":"Joint Commission Gold Seal"}]]}],["$","div","2",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Network"}],["$","div",null,{"className":"ti-val","children":"CareScout Approved"}]]}],["$","div","3",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Contract"}],["$","div",null,{"className":"ti-val","children":"BCHD · Montgomery County"}]]}],["$","div","4",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Payment"}],["$","div",null,{"className":"ti-val","children":"VA · Medicaid · LTC · Private Pay"}]]}],["$","div","5",{"className":"ti","children":[["$","div",null,{"className":"ti-lbl","children":"Available"}],["$","div",null,{"className":"ti-val","children":"24 Hours · 7 Days"}]]}]]}]
22:["$","section",null,{"className":"sec","children":["$","div",null,{"className":"inner","children":[["$","p",null,{"className":"sec-label","children":"Understanding the need"}],["$","h2",null,{"className":"sec-h","children":["What is ","Stroke Recovery Support"," at home?"]}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Stroke recovery home care provides daily support for people returning home after a stroke — helping with physical tasks, reinforcing therapy routines, providing emotional encouragement, and keeping the family connected and informed. Research consistently shows that recovery outcomes improve when patients have consistent, professional support at home."}],["$","p",null,{"className":"sec-p","children":"A stroke changes everything — sometimes in an instant. The road back is long, and it requires the kind of steady, patient support that families alone can rarely sustain. At Vitalis HealthCare, we work alongside your medical team and your family to help your loved one make the most of their recovery — day by day, step by step, at home."}]]}]}]
23:["$","section",null,{"className":"sec sec-alt","children":["$","div",null,{"className":"inner-wide","children":[["$","p",null,{"className":"sec-label","children":"Signs it's time to call"}],["$","h2",null,{"className":"sec-h","children":"How do you know when professional care is needed?"}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"28px"},"children":"Families often wait too long — not because they don't care, but because they're not sure the situation is serious enough. Here are the signs to look for."}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(3,1fr)","gap":"18px"},"children":[["$","div","Recent stroke or hospital discharge",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Recent stroke or hospital discharge"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Your loved one has just come home from a hospital or rehabilitation facility following a stroke and needs ongoing support to continue their recovery safely."}]]}],["$","div","Physical limitations from stroke",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Physical limitations from stroke"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Weakness, balance problems, difficulty walking, or limited use of one side of the body requires daily assistance and fall prevention support."}]]}],["$","div","Communication or speech challenges",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Communication or speech challenges"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Aphasia or other communication changes can be frustrating and isolating — our caregivers are trained to communicate with patience and without rushing."}]]}],["$","div","Cognitive or memory changes",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Cognitive or memory changes"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Strokes often affect memory and cognitive processing. Our team supports daily routines that compensate for these changes and reduce frustration."}]]}],["$","div","Family caregiver fatigue",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Family caregiver fatigue"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Stroke recovery can take months or years. Family members providing primary care often experience burnout — dangerous for everyone. We provide real relief."}]]}]]}]]}]}]
