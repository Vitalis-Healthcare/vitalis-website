23:["$","section",null,{"className":"sec","children":["$","div",null,{"className":"inner","children":[["$","p",null,{"className":"sec-label","children":"Understanding the need"}],["$","h2",null,{"className":"sec-h","children":["What is ","Dementia & Memory Care"," at home?"]}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Dementia is not simply forgetfulness. It changes how a person experiences time, recognizes familiar faces, communicates, and moves through daily life. Our caregivers are trained to meet people where they are — not where we think they should be — with patience, consistency, and genuine warmth."}],["$","p",null,{"className":"sec-p","children":"When a parent or spouse is living with dementia or Alzheimer's, every day brings new challenges — and new decisions. At Vitalis HealthCare, we support families through every stage of memory loss, with trained caregivers who understand that this is not just a medical condition. It's a shift in someone's whole world."}]]}]}]
24:["$","section",null,{"className":"sec sec-alt","children":["$","div",null,{"className":"inner-wide","children":[["$","p",null,{"className":"sec-label","children":"Signs it's time to call"}],["$","h2",null,{"className":"sec-h","children":"How do you know when professional care is needed?"}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"28px"},"children":"Families often wait too long — not because they don't care, but because they're not sure the situation is serious enough. Here are the signs to look for."}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(3,1fr)","gap":"18px"},"children":[["$","div","Repeated questions or confusion",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Repeated questions or confusion"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Your loved one asks the same question many times, seems disoriented at home, or gets confused about dates and people."}]]}],["$","div","Difficulty with daily tasks",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Difficulty with daily tasks"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Things like dressing, eating, or following a familiar routine have become frustrating or unsafe without help."}]]}],["$","div","Wandering or safety concerns",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Wandering or safety concerns"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Your loved one sometimes leaves the house without telling anyone, or gets lost in familiar places — a serious fall and injury risk."}]]}],["$","div","Caregiver exhaustion",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Caregiver exhaustion"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"You or another family member is the primary caregiver and you're running out of steam. That's not failure — it's human. Let us help."}]]}],["$","div","Hospital or facility discharge",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Hospital or facility discharge"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"A doctor has recommended professional home care following a diagnosis or a recent hospital stay."}]]}]]}]]}]}]
