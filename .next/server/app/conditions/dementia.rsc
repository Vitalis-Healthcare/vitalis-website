1d:T7b5,{"@context":"https://schema.org","@graph":[{"@type":"MedicalWebPage","name":"Vitalis HealthCare — Dementia & Memory Care in Silver Spring, MD","url":"https://www.vitalishealthcare.com/conditions/dementia","description":"Specialized dementia & memory care at home in Silver Spring and Montgomery County, MD. Trained caregivers, RN supervision, Medicaid & VA accepted. Call 240.716.6874.","medicalSpecialty":"Home Health Care"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What stage of dementia do you support?","acceptedAnswer":{"@type":"Answer","text":"We support all stages — from early-stage mild cognitive impairment through moderate and advanced dementia. The level of care adjusts as needs change over time."}},{"@type":"Question","name":"How do you train caregivers for dementia?","acceptedAnswer":{"@type":"Answer","text":"Our caregivers receive specialized training in dementia communication, behavioral responses, redirection techniques, and safety protocols. Our Clinical Manager provides ongoing supervision and guidance."}},{"@type":"Question","name":"Can a caregiver help with sundowning and nighttime confusion?","acceptedAnswer":{"@type":"Answer","text":"Yes. We can arrange evening and overnight care specifically to manage the increased confusion and agitation many people with dementia experience in the later hours."}},{"@type":"Question","name":"Does Maryland Medicaid cover dementia home care?","acceptedAnswer":{"@type":"Answer","text":"The Maryland Medicaid Waiver program may cover home care services for qualifying individuals with dementia. We can help you understand eligibility and navigate the process."}},{"@type":"Question","name":"What if my family member refuses help?","acceptedAnswer":{"@type":"Answer","text":"Resistance to care is very common in dementia. Our caregivers are trained in gentle, non-confrontational approaches that build trust over time. We work patiently with your loved one — and with you."}}]}]}14:[["$","script",null,{"