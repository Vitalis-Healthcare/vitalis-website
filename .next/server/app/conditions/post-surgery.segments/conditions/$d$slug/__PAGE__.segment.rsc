2:T86d,{"@context":"https://schema.org","@graph":[{"@type":"MedicalWebPage","name":"Vitalis HealthCare — Post-Surgery Recovery Care in Silver Spring, MD","url":"https://www.vitalishealthcare.com/conditions/post-surgery","description":"Post-surgery home care in Silver Spring, Rockville & Montgomery County, MD. Medication management, wound care & recovery support. Licensed, certified. Call 240.716.6874.","medicalSpecialty":"Home Health Care"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"When can post-surgery care start?","acceptedAnswer":{"@type":"Answer","text":"We can often arrange care to begin on the day of hospital discharge or the following morning. Contact us before the planned discharge date if possible so we can plan ahead."}},{"@type":"Question","name":"What surgeries do you typically support?","acceptedAnswer":{"@type":"Answer","text":"We support recovery from a wide range of procedures including joint replacement (hip, knee), cardiac surgery, abdominal surgery, cancer-related surgery, spinal procedures, and general orthopedic operations."}},{"@type":"Question","name":"Does Medicare cover post-surgery home care?","acceptedAnswer":{"@type":"Answer","text":"Medicare may cover skilled services — including skilled nursing, physical therapy, and occupational therapy — when ordered by a physician after a qualifying hospital stay. Non-medical support like personal care may be covered by Medicaid Waiver or Long-Term Care Insurance. We'll help you work through what applies."}},{"@type":"Question","name":"How long does post-surgery care typically last?","acceptedAnswer":{"@type":"Answer","text":"It varies by procedure and individual recovery. Some clients need intensive support for 2–4 weeks. Others benefit from more moderate help for 1–3 months. We reassess regularly and adjust care as your loved one improves."}},{"@type":"Question","name":"Can your nurses communicate with my loved one's surgeon?","acceptedAnswer":{"@type":"Answer","text":"Yes. Our clinical team can coordinate with your surgeon's office and any rehab or physical therapy providers. We believe good recovery care is collaborative."}}]}]}0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","nav",null,{"className":"nav-sticky","children":["$","div",null,{"className":"nav-inner","style":{"display":"flex","alignItems":"center","justifyContent":"space-between","padding":"16px 48px","maxWidth":"1280px","margin":"0 auto"},"children":[["$","$L3",null,{"href":"/","style":{"display":"flex","alignItems":"center","gap":"10px"},"children":[["$","svg",null,{"width":"34","height":"34","viewBox":"0 0 34 34","fill":"none","children":[["$","rect",null,{"width":"34","height":"34","rx":"9","fill":"#eaf3de"}],["$","text",null,{"x":"17","y":"23","textAnchor":"middle","fontFamily":"Georgia,serif","fontSize":"13","fontWeight":"500","fill":"#27500a","children":"V+"}]]}],["$","span",null,{"style":{"fontFamily":"var(--font-lora), Georgia, serif","fontSize":"17px","color":"var(--text)"},"children":"Vitalis HealthCare"}]]}],["$","div",null,{"className":"nav-links","style":{"display":"flex","gap":"28px"},"children":[["$","$L3",null,{"href":"/#services","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Services"}],["$","$L3",null,{"href":"/#conditions","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Conditions"}],["$","$L3",null,{"href":"/#team","style":{"fontSize":"14px","color":"var(--muted)"},"children":"About Us"}],["$","$L3",null,{"href":"/blog","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Blog"}],["$","$L3",null,{"href":"/careers","style":{"fontSize":"14px","color":"var(--muted)"},"children":"Careers"}]]}],["$","div",null,{"style":{"display":"flex","alignItems":"center","gap":"20px"},"children":[["$","a",null,{"href":"tel:2407166874","style":{"fontSize":"14px","fontWeight":500,"color":"var(--g-bd)"},"children":"240.716.6874"}],"$L4"]}]]}]}],"$L5"