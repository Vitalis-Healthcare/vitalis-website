8:["$","section",null,{"className":"sec","children":["$","div",null,{"className":"inner","children":[["$","p",null,{"className":"sec-label","children":"Understanding the need"}],["$","h2",null,{"className":"sec-h","children":["What is ","Post-Surgery Recovery Care"," at home?"]}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"16px"},"children":"Post-surgery recovery care is professional, structured support provided in your home during the critical weeks after an operation. It bridges the gap between hospital discharge and full independence — reducing the risk of readmission, complications, or falls that can set recovery back significantly."}],["$","p",null,{"className":"sec-p","children":"Coming home after surgery is a vulnerable moment. You're relieved to be out of the hospital, but suddenly the routine of recovery — medications, movement, wound care, follow-up appointments — falls on you and your family. Vitalis HealthCare takes that weight off. We give your loved one the clinical support and daily help they need to heal safely and fully at home."}]]}]}]
9:["$","section",null,{"className":"sec sec-alt","children":["$","div",null,{"className":"inner-wide","children":[["$","p",null,{"className":"sec-label","children":"Signs it's time to call"}],["$","h2",null,{"className":"sec-h","children":"How do you know when professional care is needed?"}],["$","p",null,{"className":"sec-p","style":{"marginBottom":"28px"},"children":"Families often wait too long — not because they don't care, but because they're not sure the situation is serious enough. Here are the signs to look for."}],["$","div",null,{"style":{"display":"grid","gridTemplateColumns":"repeat(3,1fr)","gap":"18px"},"children":[["$","div","Hospital discharge without full independence",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Hospital discharge without full independence"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Your surgeon or discharge team has recommended professional home support following an operation — hip replacement, cardiac surgery, abdominal surgery, or other procedures."}]]}],["$","div","Medication management concerns",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Medication management concerns"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Multiple medications on a new schedule, especially with pain management, are hard to manage alone. Mistakes can be dangerous."}]]}],["$","div","Wound or incision care needs",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Wound or incision care needs"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Proper wound care at home is essential to prevent infection. Our skilled nursing team can manage dressings, monitor for complications, and coordinate with your surgeon."}]]}],["$","div","Limited mobility during recovery",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Limited mobility during recovery"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Getting in and out of bed, using the bathroom safely, or navigating stairs is difficult and risky without assistance during early recovery."}]]}],["$","div","Family caregiver overwhelm",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Warning sign"}],["$","div",null,{"style":{"fontSize":"15px","fontWeight":500,"color":"var(--text)","marginBottom":"8px"},"children":"Family caregiver overwhelm"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"A spouse or adult child is trying to manage post-surgical care on top of their own life and responsibilities — and needs real relief."}]]}]]}]]}]}]
