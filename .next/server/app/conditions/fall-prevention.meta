{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/conditions/layout,_N_T_/conditions/[slug]/layout,_N_T_/conditions/[slug]/page,_N_T_/conditions/fall-prevention"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/conditions/$d$slug/__PAGE__",
    "/conditions/$d$slug",
    "/conditions",
    "/_index",
    "/_head"
  ]
}