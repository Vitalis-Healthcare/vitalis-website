9:["$","section",null,{"className":"sec sec-alt","id":"services","children":["$","div",null,{"className":"inner","children":[["$","div",null,{"style":{"textAlign":"center","marginBottom":"44px"},"children":[["$","p",null,{"className":"sec-label","children":"What we do"}],["$","h2",null,{"className":"sec-h","children":"Home care that covers every need"}],["$","p",null,{"className":"sec-p","style":{"maxWidth":"580px","marginInline":"auto"},"children":"Whether your loved one needs a friendly face, help with daily tasks, or skilled medical care at home, we have a trained and supervised team ready to help."}]]}],["$","div",null,{"className":"three-col","children":[["$","div","Companion Care",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Companion Care"}],["$","div",null,{"style":{"fontSize":"17px","fontWeight":500,"color":"var(--text)","marginBottom":"10px"},"children":"Someone to be there"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Loneliness is one of the biggest health risks for seniors. Our companions offer real conversation, shared meals, light errands, and the kind of consistent presence that keeps your loved one engaged — and not forgotten."}]]}],["$","div","Personal Care",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Personal Care"}],["$","div",null,{"style":{"fontSize":"17px","fontWeight":500,"color":"var(--text)","marginBottom":"10px"},"children":"Help with daily life, done with dignity"}],["$","p",null,{"style":{"fontSize":"14px","lineHeight":1.7,"color":"var(--muted)"},"children":"Bathing, dressing, grooming, and getting around the house — our aides provide respectful, professional help with the things that matter most to your loved one's comfort and self-esteem, every single day."}]]}],["$","div","Skilled Nursing",{"className":"card","children":[["$","span",null,{"className":"pill","children":"Skilled Nursing"}],["$","div",null,{"style"